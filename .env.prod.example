# ══════════════════════════════════════════════════════════
# DevPulse 生产环境配置
# ══════════════════════════════════════════════════════════
# 使用方法：
#   1. cp .env.prod.example .env
#   2. 修改所有 <CHANGE_ME> 为真实值
#   3. docker compose -f docker-compose.prod.yml up -d --build

# ─── 数据库 ──────────────────────────────────────────────
POSTGRES_USER=devpulse
POSTGRES_PASSWORD=<CHANGE_ME_strong_password>
POSTGRES_DB=devpulse

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME_strong_password>

# ─── JWT 密钥（生成方法：openssl rand -base64 48）────────
JWT_SECRET=<CHANGE_ME_random_64_chars>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<CHANGE_ME_random_64_chars_different_from_above>
JWT_REFRESH_EXPIRES_IN=7d

# ─── 应用 ────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
# APP_URL：后端对外访问基础 URL
#   同源部署（Nginx 同时代理前端和后端）：留空
#   分域部署（前端 CDN + 后端独立域名）：填 https://api.your-domain.com
APP_URL=

# ─── 管理员（首次启动时自动创建）────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=<CHANGE_ME_strong_password>

# ─── 邮件（SMTP）──────────────────────────────────────────
# 使用阿里云邮件推送 / 腾讯企业邮 / SendGrid 等
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_USER=noreply@your-domain.com
SMTP_PASS=<CHANGE_ME_smtp_password>
MAIL_FROM=noreply@your-domain.com

# ─── 上传 ────────────────────────────────────────────────
MAX_FILE_SIZE=2097152

# ─── Nginx ───────────────────────────────────────────────
NGINX_PORT=80
