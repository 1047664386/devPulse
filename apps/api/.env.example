# Database
POSTGRES_USER=devpulse
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=devpulse
DATABASE_URL=postgresql://devpulse:<your-db-password>@localhost:5432/devpulse

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=<random-32-byte-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<random-32-byte-secret>
JWT_REFRESH_EXPIRES_IN=7d

# App
API_PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:5173

# Admin bootstrap (used by PrismaService on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<admin-password>

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2097152
