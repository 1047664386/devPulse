# Database
POSTGRES_USER=devpulse
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=devpulse
DATABASE_URL=postgresql://devpulse:<your-db-password>@localhost:5432/devpulse

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=<random-32-byte-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<random-32-byte-secret>
JWT_REFRESH_EXPIRES_IN=7d

# App
API_PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:5173
# APP_URL：后端对外访问的基础 URL，用于拼接上传文件完整路径
#   留空 → 返回相对路径 /uploads/xxx（适用于开发环境、同源部署）
#   填写 → 返回完整 URL https://api.example.com/uploads/xxx（适用于前后端分域部署）
APP_URL=

# Admin bootstrap (used by PrismaService on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<admin-password>

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2097152

# Email — 三种配置模式：
#   1. 本地 Mailpit：仅填 SMTP_HOST + SMTP_PORT，USER/PASS 留空（无需认证）
#      HOST 务必用 127.0.0.1（不要用 localhost，否则 macOS 下会被解析为 IPv6
#      ::1，连接 Mailpit 时报 ECONNREFUSED ::1:1025）
#      启动 Mailpit：docker compose up -d mailpit；查看邮件：http://localhost:8025
#   2. Ethereal 测试邮箱：全部留空 → 自动使用 ethereal.email（邮件不真实送达）
#   3. 生产环境：填齐全部变量 → 通过真实邮件服务商发送
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@devpulse.com
